{
    "compilerOptions": {
        "target": "ES2020",
        "lib": ["ES2020"],
        "module": "ESNext",
        "moduleResolution": "Bundler",
        "strict": true,
        "declaration": true,
        "declarationMap": true,
        "sourceMap": true,
        "isolatedModules": true,
        "esModuleInterop": true,
        "forceConsistentCasingInFileNames": true,
        "ignoreDeprecations": "6.0",
        "skipLibCheck": true,
        "types": ["node"]
    },
    "include": ["src/**/*.ts", "tests/**/*.ts", "*.config.ts"]
}
